{
  "name": "mep-listening-simulator",
  "version": "1.0.0",
  "description": "MEPT Section IV listening simulator with Gemini and OpenAI-compatible exam generation.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "worker:dev": "wrangler dev",
    "secrets:bulk": "wrangler secret bulk .env",
    "deploy": "wrangler deploy",
    "deploy:env": "wrangler deploy --secrets-file .env"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  },
  "license": "MIT"
}
